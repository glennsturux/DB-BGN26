    Kode_Pesanan VARCHAR(4) NOT NULL,
	Nama_Pesanan VARCHAR(100) NOT NULL,
    Kode_Barang VARCHAR(4),
    PRIMARY KEY (Kode_Pesanan),
    CONSTRAINT fk_pesanan_barang FOREIGN KEY (Kode_Barang)
    REFERENCES Barang(Kode_Barang)
);

